@page "/test"
@attribute [Authorize]

<div class="test-page">
    <div class="test-page__header">
        <div class="test-page__title-row">
            <h1>Test Center</h1>
            <span class="test-chip">Actions: 12</span>
        </div>
        <p>Platform services, handler pages, and navigation actions.</p>
        <div class="test-summary">
            <span class="test-chip">Assets: @assets.Count</span>
            <span class="test-chip">System fields: @systemInformation.Count</span>
            <span class="test-chip">Directory: @(string.IsNullOrWhiteSpace(selectedDirectory) ? "None" : "Selected")</span>
        </div>
    </div>

    <div class="test-grid">
        <section class="test-card">
            <h2>Navigation</h2>
            <div class="test-actions">
                <button class="btn btn-primary" @onclick='() => NavigateTo("/")'>Home</button>
                <button class="btn btn-primary" @onclick='() => NavigateTo("/counter")'>Counter</button>
                <button class="btn btn-primary" @onclick='() => NavigateTo("/weather")'>Weather</button>
                <button class="btn btn-warning" @onclick='() => NavigateTo("/loading")'>Loading</button>
                <button class="btn btn-warning" @onclick='() => NavigateTo("/forbidden")'>Forbidden</button>
                <button class="btn btn-warning" @onclick='() => NavigateTo("/not-found")'>Not Found</button>
                <button class="btn btn-secondary" @onclick='() => NavigateTo("/login")'>Login</button>
            </div>
        </section>

        <section class="test-card">
            <h2>Platform Services</h2>

            <div class="mb-3">
                <label for="asset-path" class="form-label">Asset path</label>
                <input id="asset-path" class="form-control" @bind="assetPath" placeholder="resources/raw/languages/en-us.json" />
            </div>

            <div class="test-actions">
                <button class="btn btn-primary" @onclick="ListAssetsAsync">List Assets</button>
                <button class="btn btn-info" @onclick="PickRandomAsset">Pick Random Asset</button>
                <button class="btn btn-primary" @onclick="ReadAssetContent">Read Asset Content</button>
                <button class="btn btn-primary" @onclick="PickDirectoryAsync">Pick Directory</button>
                <button class="btn btn-primary" @onclick="OpenDirectoryAsync" disabled="@string.IsNullOrWhiteSpace(selectedDirectory)">Open Directory</button>
                <button class="btn btn-primary" @onclick="SendLocalNotificationAsync">Send Notification</button>
                <button class="btn btn-primary" @onclick="ScanBarcodeAsync">Scan Barcode</button>
            </div>
        </section>

        <section class="test-card">
            <h2>Quick Tests</h2>
            <div class="test-actions">
                <button class="btn btn-success" @onclick="RunQuickHealthCheckAsync">Run Health Check</button>
                <button class="btn btn-secondary" @onclick="ClearOutput">Clear Output</button>
            </div>
        </section>

        <section class="test-card">
            <h2>System Information</h2>
            <div class="test-actions">
                <button class="btn btn-success" @onclick="RefreshSystemInformation">Refresh Info</button>
            </div>

            @if (systemInformation.Count > 0)
            {
                <dl class="test-info-grid">
                    @foreach (var item in systemInformation)
                    {
                        <dt>@item.Key</dt>
                        <dd>@item.Value</dd>
                    }
                </dl>
            }
        </section>

        <section class="test-card">
            <h2>Output</h2>
            <div class="mb-3">
                <label for="asset-filter" class="form-label">Asset filter</label>
                <input id="asset-filter" class="form-control" @bind="assetFilter" placeholder="Filter assets list" />
            </div>

            <div class="test-output">
                @statusMessage
            </div>

            @if (lastUpdatedAt.HasValue)
            {
                <div class="test-meta">Last update: @lastUpdatedAt.Value.LocalDateTime.ToString("G")</div>
            }

            @if (assets.Count > 0)
            {
                <h3>Assets (@FilteredAssets.Count())</h3>
                <ul class="test-list">
                    @foreach (var asset in FilteredAssets.Take(25))
                    {
                        <li>@asset</li>
                    }
                </ul>
            }
        </section>
    </div>
</div>

@code {
    private string statusMessage = "Ready.";
    private string assetPath = "";
    private string assetFilter = "";
    private string selectedDirectory = "";
    private List<string> assets = [];
    private Dictionary<string, string> systemInformation = [];
    private DateTimeOffset? lastUpdatedAt;

    private IEnumerable<string> FilteredAssets =>
        string.IsNullOrWhiteSpace(assetFilter)
            ? assets
            : assets.Where(asset => asset.Contains(assetFilter, StringComparison.OrdinalIgnoreCase));

    private void NavigateTo(string route)
    {
        _navigation.NavigateTo(route, false);
    }

    private void SetStatus(string message)
    {
        statusMessage = message;
        lastUpdatedAt = DateTimeOffset.Now;
    }

    private async Task ListAssetsAsync()
    {
        try
        {
            assets = (await _platform.ListAssetsAsync()).ToList();
            SetStatus($"Loaded {assets.Count} assets.");
            if (string.IsNullOrWhiteSpace(assetPath))
            {
                assetPath = assets.FirstOrDefault() ?? string.Empty;
            }
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private void ReadAssetContent()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(assetPath))
            {
                SetStatus("Provide an asset path first.");
                return;
            }

            var content = _platform.ReadAssetContent(assetPath);
            SetStatus(string.IsNullOrWhiteSpace(content)
                ? "Asset is empty."
                : $"Asset content preview: {content[..Math.Min(content.Length, 300)]}");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private async Task PickDirectoryAsync()
    {
        try
        {
            selectedDirectory = await _platform.PickDirectory() ?? string.Empty;
            SetStatus(string.IsNullOrWhiteSpace(selectedDirectory)
                ? "No directory selected."
                : $"Selected directory: {selectedDirectory}");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private async Task OpenDirectoryAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(selectedDirectory))
            {
                SetStatus("Pick a directory first.");
                return;
            }

            await _platform.OpenDirectory(selectedDirectory);
            SetStatus($"Opened directory: {selectedDirectory}");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private async Task SendLocalNotificationAsync()
    {
        try
        {
            await _platform.SendLocalNotification("Test notification", "This notification was triggered from Test Center.");
            SetStatus("Notification sent.");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private async Task ScanBarcodeAsync()
    {
        try
        {
            var result = await _platform.ScanBarcodeAsync();
            SetStatus(string.IsNullOrWhiteSpace(result) ? "No barcode scanned." : $"Barcode result: {result}");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private async Task RefreshSystemInformation()
    {
        try
        {
            var storageTotalTask = Task.Run(() => _platform.GetStorage(false).ToFormattedBytes());
            var storageAvailableTask = Task.Run(() => _platform.GetStorage(true).ToFormattedBytes());
            var processorTask = Task.Run(_platform.GetProcessor);
            var ramTask = Task.Run(() => _platform.GetRam().ToFormattedBytes());
            var graphicsCardTask = Task.Run(() => string.Join(" | ", _platform.GetGraphicsCard()));
            var osNameTask = Task.Run(_platform.GetOsName);
            var osVersionTask = Task.Run(_platform.GetOsVersion);
            var osArchitectureTask = Task.Run(_platform.GetOsArchitecture);
            var machineNameTask = Task.Run(_platform.GetMachineName);
            var userNameTask = Task.Run(_platform.GetUserName);

            await Task.WhenAll(
                storageTotalTask,
                storageAvailableTask,
                processorTask,
                ramTask,
                graphicsCardTask,
                osNameTask,
                osVersionTask,
                osArchitectureTask,
                machineNameTask,
                userNameTask
            );

            systemInformation = new Dictionary<string, string>
            {
                ["Storage Total"] = storageTotalTask.Result,
                ["Storage Available"] = storageAvailableTask.Result,
                ["Processor"] = processorTask.Result,
                ["RAM"] = ramTask.Result,
                ["Graphics Card"] = graphicsCardTask.Result,
                ["OS Name"] = osNameTask.Result,
                ["OS Version"] = osVersionTask.Result,
                ["OS Architecture"] = osArchitectureTask.Result,
                ["Machine Name"] = machineNameTask.Result,
                ["User Name"] = userNameTask.Result
            };

            SetStatus("System information refreshed.");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private void PickRandomAsset()
    {
        try
        {
            if (assets.Count == 0)
            {
                SetStatus("Load assets first.");
                return;
            }

            assetPath = assets[Random.Shared.Next(0, assets.Count)];
            SetStatus($"Selected random asset: {assetPath}");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private async Task RunQuickHealthCheckAsync()
    {
        try
        {
            await ListAssetsAsync();
            await RefreshSystemInformation();
            SetStatus($"Health check done. Assets: {assets.Count}, System fields: {systemInformation.Count}.");
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message);
        }
    }

    private void ClearOutput()
    {
        assets.Clear();
        systemInformation.Clear();
        assetFilter = string.Empty;
        selectedDirectory = string.Empty;
        assetPath = string.Empty;
        SetStatus("Ready.");
    }

    protected override Task OnInitializedAsync()
    {
        lastUpdatedAt = DateTimeOffset.Now;
        return base.OnInitializedAsync();
    }
}
