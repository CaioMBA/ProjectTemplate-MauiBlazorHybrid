{
  "AppName": "MAUI_HYBRID-TEMPLATE",
  "AppVersion": "1",
  "DataBaseConnections": [
    {
      "DataBaseID": "DEFAULT",
      "Type": "POSTGRESQL",
      "ConnectionString": "Data Source={DATABASE_HOST};Initial Catalog={DATABASE_NAME};User ID={DATABASE_USERNAME};Password={DATABASE_PASSWORD};Connect Timeout=100;TrustServerCertificate=True"
    }
  ],
  "ApiConnections": [
    {
      "ApiID": "Notifications",
      "Url": "{NOTIFICATIONS_API_URL}",
      "EndPoints": [
        {
          "EndPointID": "SendNotification",
          "Path": "/api/Notification/Send",
          "Method": "POST",
          "Type": "REST"
        }
      ]
    }
  ]
}